# README is rendered from this template into the package at release time, so the
# template itself does not belong in the deployable chart.
README.md.gotmpl
# CI-only fixtures (extra values files) and the helm-unittest suite are read from
# the source tree by ct / helm unittest, never from the package.
ci/
tests/
# Artifact Hub repository metadata is pushed to the registry under the
# :artifacthub.io tag (hack/push-artifacthub-metadata.sh), not shipped in the chart.
artifacthub-repo.yml
