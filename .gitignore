# SPDX-FileCopyrightText: The helm-charts Authors
# SPDX-License-Identifier: 0BSD

# ilo dev-shell args — per-machine (local filesystem paths), never shared
.ilo.rc

# helm dependency vendoring + packaging output
charts/*/charts/
charts/*/Chart.lock
*.tgz

# README is rendered from README.md.gotmpl into the package at release time,
# so the rendered file is a build artifact rather than committed source.
charts/*/README.md

# values.schema.json is generated by helm-schema into the package at release
# time, so the schema is a build artifact rather than committed source.
charts/*/values.schema.json

# JetBrains
.idea/
# JetBrains module files
*.iml
.cache/

# CRDs are vendored from each controller's release at package time by
# hack/vendor-chart-crds.sh (CI jobs + the release pipeline regenerate them),
# so the chart's CRDs always match the appVersion it deploys. They are a build
# artifact, not committed source. Run hack/vendor-chart-crds.sh charts/<chart>
# before `helm template`/`helm unittest`/`helm install` from a checkout.
charts/*/templates/crd-*.yaml

# direnv nix-direnv build cache (real-nix contributors may add a local .envrc).
.direnv/

# nix build output symlink
result
result-*

# Generated by hack/vendor-rbac.sh from the controller's config/rbac/role.yaml at the
# chart's appVersion (build artifact, like the CRDs above) — never committed, so the
# chart's controller RBAC can't drift from what the released binary declares.
charts/*/templates/clusterrole-controller*.yaml
