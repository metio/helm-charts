# ilo dev-shell args — per-machine (local filesystem paths), never shared
.ilo.rc

# helm dependency vendoring + packaging output
charts/*/charts/
charts/*/Chart.lock
*.tgz

# README is rendered from README.md.gotmpl into the package at release time,
# so the rendered file is a build artifact rather than committed source.
charts/*/README.md

# JetBrains
.idea/
# JetBrains module files
*.iml
.cache/
